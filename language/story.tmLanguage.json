{
	"name": "Story",
	"scopeName": "source.story",
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"patterns": [{ "include": "#valid" }, { "include": "#invalid" }],
	"repository": {
		"valid": {
			"match": "^(`)[^`]*(`)$",
			"captures": {
				"1": {
					"name": "entity.name.class.story"
				},
				"2": {
					"name": "entity.name.class.story"
				}
			}
		},
		"invalid": {
			"match": "^(?!`[^`]*`$).+",
			"name": "entity.name.class.story"
		}
	}
}
